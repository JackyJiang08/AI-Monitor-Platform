# Copy this file to .env.local and fill in your keys.

# Anthropic API key — powers the news translation, structuring, and quant analysis
# pipeline (fetch_rss_news.js / backfill.js). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# Optional — only needed for backfill.js (historical backfill via GNews)
GNEWS_API_KEY=""

# Optional — base URL of the trading backend (live_trade_bench) for the Trading tab.
# Defaults to http://localhost:8000 when unset; the Trading tab only works when that
# backend is running locally (it is not deployed with the Vercel frontend).
NEXT_PUBLIC_API_URL="http://localhost:8000"
